# Backend Configuration Example
PORT=4000
NODE_ENV=development

# Security
# Run 'node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"' to generate a strong secret
JWT_SECRET=your_jwt_secret_here

# Admin Password (Default: admin1234)
# Use bcrypt to generate a new hash if you want to change it
ADMIN_PASSWORD_HASH=$2b$10$Oi5SNkg.prlUwoXc2Y3UM.H8D2nlLqfvnQmPVqF0uat9jOyrrDwA2

# Database
# For SQLite (Development):
# No DATABASE_URL needed, it will use ./dev.sqlite3 by default

# For PostgreSQL (Production/Docker):
# DATABASE_URL=postgresql://user:password@db:5432/qr_ordering
